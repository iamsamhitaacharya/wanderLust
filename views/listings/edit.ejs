<%=layout("layouts/boilerplate")%>
<body>
    <div class="row">
        <div class="col col-8 offset-2">
    <h3 class="mt-4 mb-4">Fill the form to edit listing</h3>
    <form method="POST" action="/listings/<%=listing._id%>?_method=PUT">
<div class="mb-4">
            <label for="title" class="form-label">Title</label>
            <input name="listing[title]" id="title" value="<%= listing.title %>" type="text" class="form-control">
        </div>
        <div class="mb-4">
            <label for="description" class="form-label">Description</label>
             <textarea name="listing[description]" id="description"  class="form-control"> <%= listing.description %> </textarea>
        </div>
        <div class="mb-4">
            <label for="image" class="form-label">Image link</label>
             <input name="listing[image][url]" id="image" value="<%= listing.image.url %>" type="text" class="form-control">
        </div>
        <div class="row">
        <div class=" col-md-4 mb-4">
            <label for="price"class="form-label">Price</label>
             <input name="listing[price]"  id="price" value="<%= listing.price %>" type="number" class="form-control">
        </div>
        <div class=" col-md-8 mb-4">
            <label for="country" class="form-label">Country</label>
            <input name="listing[country]" id="country" value="<%= listing.country %>" type="text" class="form-control">
        </div>
        </div>
        <div class="mb-4">
            <label for="location" class="form-label">Location</label>
            <input name="listing[location]" id="location" value="<%= listing.location %>" type="text" class="form-control">
        </div>
        <button class="btn btn-dark mb-4 edit-btn">Edit</button>
    </form>
    </div>
    </div>
</body>
