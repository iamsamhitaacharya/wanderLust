<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wanderlust</title>
</head>
<body>
    <h3>Fill this form to add new listing</h3>
    <form method="POST" action="/listings">
        <input name="listing[title]" placeholder="Title"><br><br>
        <textarea name="listing[description]" placeholder="description"></textarea><br><br>
        <input name="listing[image][url]" placeholder="image url"><br><br>
        <input name="listing[price]" placeholder="price"><br><br>
        <input name="listing[country]" placeholder="country"><br><br>
        <input name="listing[location]" placeholder="location"><br><br>
        <button>Add</button>
    </form>
</body>
</html>